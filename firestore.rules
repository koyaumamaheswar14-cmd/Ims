rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function hasRole(role) {
      return isSignedIn() && (role in getUserData().roles || 'admin' in getUserData().roles);
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // User Profiles
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if hasRole('admin') || (isOwner(userId) && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['roles', 'status']));
      allow delete: if hasRole('admin');
    }
    
    // Invites
    match /invites/{inviteId} {
      allow read: if isSignedIn();
      allow create: if hasRole('admin') || hasRole('manager');
      allow update: if hasRole('admin') || (isSignedIn() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']));
      allow delete: if hasRole('admin');
    }
    
    // Audit Logs
    match /audit_logs/{logId} {
      allow read: if hasRole('admin') || hasRole('manager');
      allow create: if isSignedIn(); // Allow logging from client
      allow update, delete: if false; // Logs are immutable
    }
  }
}
